# Supabase — fill these in from your Supabase project's Settings -> API page.
# Copy this file to `.env.local` and replace the placeholders.
# Never commit `.env.local` (already gitignored).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-eyJ...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-eyJ...
