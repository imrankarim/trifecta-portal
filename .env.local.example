# Supabase — fill these in from your Supabase project's Settings -> API page.
# Copy this file to `.env.local` and replace the placeholders.
# Never commit `.env.local` (already gitignored).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-eyJ...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-eyJ...

# Cron auth — Vercel Cron sends `Authorization: Bearer ${CRON_SECRET}`.
# Generate a strong random string. Set this in Vercel env vars too.
CRON_SECRET=

# Resend (transactional email — sends the weekly at-risk digest).
# Get an API key at https://resend.com (free tier is plenty for staging).
RESEND_API_KEY=re_...
# Sender address. Default is Resend's verified `onboarding@resend.dev` (works
# without any domain setup; recipients see "Trifecta <onboarding@resend.dev>").
# Once you've verified a custom domain in Resend, switch to e.g.
# `Trifecta <digest@trifecta-portal.app>`.
RESEND_FROM=Trifecta <onboarding@resend.dev>
